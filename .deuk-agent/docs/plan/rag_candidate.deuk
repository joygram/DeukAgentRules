namespace deuk_agent_rules.rag

enum RagCandidateSourceType {
    Unknown = 0
    Ticket = 1
    Plan = 2
    Report = 3
    Scratch = 4
    External = 5
}

enum RagCandidateStatus {
    Raw = 0
    Candidate = 1
    Review = 2
    Approved = 3
    ActiveIndex = 4
    Rejected = 5
    Deprecated = 6
}

struct RagCandidate {
    1> string id = ""
    2> string source_path = ""
    3> RagCandidateSourceType source_type = Unknown
    4> RagCandidateStatus status = Candidate
    5> string summary = ""
    6> string problem = ""
    7> string decision = ""
    8> list<string> evidence
    9> list<string> scope
    10> list<string> rules
    11> double confidence = 0
    12> string created_at = ""
    13> string updated_at = ""
    14> list<string> tags
    15> list<string> notes
}

struct RagCandidateBatch {
    1> int32 schema_version = 1
    2> string generated_at = ""
    3> list<RagCandidate> candidates
}
