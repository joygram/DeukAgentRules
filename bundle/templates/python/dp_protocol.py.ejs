"""
DeukPack Python Runtime — Unified Protocol Factory
"""
import io
from typing import Any, Dict, List, Optional, Tuple

from .dp_base import DpWireType, DpProtocolError, DP_WIRE_ENVELOPE, DpProtocolBase
from .dp_binary import DpTBinaryProtocol
from .dp_compact import DpTCompactProtocol
from .dp_pack import DpPackProtocol
from .dp_json import DpJsonProtocol
from .dp_protobuf import DpProtobufProtocol

class DpProtocol:
    """
    Unified factory for DeukPack protocols.
    """
    @staticmethod
    def create(
        fmt: str = "tbinary",
        buffer: Optional[io.BytesIO] = None,
        little_endian: bool = False,
        **kwargs: Any,
    ) -> DpProtocolBase:
        f = fmt.lower()
        if f == "tbinary": return DpTBinaryProtocol(buffer, little_endian=little_endian)
        if f == "tcompact": return DpTCompactProtocol(buffer)
        if f in ("pack", "dpk"): return DpPackProtocol(buffer)
        if f in ("protobuf", "proto", "pb"): return DpProtobufProtocol(buffer)
        if f == "json": return DpJsonProtocol(**kwargs)
        raise DpProtocolError(f"Unknown DeukPack protocol format: '{f}'")

    @staticmethod
    def detect(data: bytes) -> str:
        if len(data) >= 3 and data[:3] == DP_WIRE_ENVELOPE: return "pack"
        if len(data) >= 1 and data[0] in (ord('{'), ord('[')): return "json"
        return "tbinary"

    @staticmethod
    def generic_serialize(obj: Any, fields: List[Tuple], prot: DpProtocolBase, is_dict: bool = False) -> None:
        """
        Generic metadata-driven serialization engine.
        """
        prot.write_struct_begin(len(fields))
        for fid, fname, wire_type, tref, default in fields:
            val = (obj.get(fname) if is_dict else getattr(obj, fname, None))
            if val is None or val == default:
                continue
            # Optimization: Skip empty collections
            if wire_type in (DpWireType.LIST, DpWireType.SET, DpWireType.MAP) and hasattr(val, "__len__") and len(val) == 0:
                continue
            prot.write_field_begin(wire_type, fid, fname)
            DpProtocol._write_val(prot, wire_type, tref, val, 0)
        prot.write_field_stop()
        prot.write_struct_end()

    @staticmethod
    def generic_deserialize(obj_or_cls: Any, fields: List[Tuple], prot: DpProtocolBase, is_dict: bool = False) -> Any:
        """
        Generic metadata-driven deserialization engine.
        """
        obj = obj_or_cls if (is_dict or not isinstance(obj_or_cls, type)) else obj_or_cls()
        field_map = {f[0]: f for f in fields}
        name_map = {f[1]: f for f in fields}
        
        prot.read_struct_begin()
        while True:
            wire_type, field_id, field_name = prot.read_field_begin()
            if wire_type == DpWireType.STOP:
                break
            
            f_meta = field_map.get(field_id) or name_map.get(field_name)
            if f_meta:
                _, fname, meta_wire_type, tref, _ = f_meta
                
                is_strict = getattr(prot, "IS_STRICT_TYPED", True)
                if is_strict and wire_type != meta_wire_type:
                    # Mismatch in binary format: safe skip to prevent corruption
                    prot.skip(wire_type)
                else:
                    val = DpProtocol._read_val(prot, meta_wire_type, tref, 0)
                    if is_dict:
                        obj[fname] = val
                    else:
                        setattr(obj, fname, val)
            else:
                prot.skip(wire_type)
        prot.read_struct_end()
        return obj

    @staticmethod
    def _write_val(prot: DpProtocolBase, wire_type: int, tref: Any, val: Any, depth: int) -> None:
        prot._check_depth(depth)
        if wire_type == DpWireType.BOOL: prot.write_bool(val)
        elif wire_type == DpWireType.BYTE: prot.write_byte(val)
        elif wire_type == DpWireType.INT16: prot.write_int16(val)
        elif wire_type == DpWireType.INT32: prot.write_int32(val)
        elif wire_type == DpWireType.INT64: prot.write_int64(val)
        elif wire_type == DpWireType.DOUBLE: prot.write_double(val)
        elif wire_type == DpWireType.STRING: prot.write_string(val)
        elif wire_type == DpWireType.BINARY: prot.write_binary(val)
        elif wire_type == DpWireType.STRUCT:
            if hasattr(tref, 'serialize'): tref.serialize(val, prot)
            elif hasattr(val, 'serialize'): val.serialize(prot)
        elif wire_type in (DpWireType.LIST, DpWireType.SET):
            etref = tref[1]; ewt = DpProtocol._get_wire_type(etref)
            if wire_type == DpWireType.SET: prot.write_set_begin(ewt, len(val))
            else: prot.write_list_begin(ewt, len(val))
            for e in val: DpProtocol._write_val(prot, ewt, etref, e, depth + 1)
            if wire_type == DpWireType.SET: prot.write_set_end()
            else: prot.write_list_end()
        elif wire_type == DpWireType.MAP:
            ktref, vtref = tref[1], tref[2]
            kwt, vwt = DpProtocol._get_wire_type(ktref), DpProtocol._get_wire_type(vtref)
            prot.write_map_begin(kwt, vwt, len(val))
            for k, v in val.items():
                DpProtocol._write_val(prot, kwt, ktref, k, depth + 1)
                DpProtocol._write_val(prot, vwt, vtref, v, depth + 1)
            prot.write_map_end()

    @staticmethod
    def _read_val(prot: DpProtocolBase, wire_type: int, tref: Any, depth: int) -> Any:
        prot._check_depth(depth)
        if wire_type == DpWireType.BOOL: return prot.read_bool()
        if wire_type == DpWireType.BYTE: return prot.read_byte()
        if wire_type == DpWireType.INT16: return prot.read_int16()
        if wire_type == DpWireType.INT32: return prot.read_int32()
        if wire_type == DpWireType.INT64: return prot.read_int64()
        if wire_type == DpWireType.DOUBLE: return prot.read_double()
        if wire_type == DpWireType.STRING: return prot.read_string()
        if wire_type == DpWireType.BINARY: return prot.read_binary()
        if wire_type == DpWireType.STRUCT:
            if hasattr(tref, 'deserialize'): return tref.deserialize(prot)
            return None
        if wire_type in (DpWireType.LIST, DpWireType.SET):
            if wire_type == DpWireType.SET: wt, count = prot.read_set_begin()
            else: wt, count = prot.read_list_begin()
            etref = tref[1]; ewt = DpProtocol._get_wire_type(etref)
            res = [DpProtocol._read_val(prot, ewt, etref, depth + 1) for _ in range(count)]
            if wire_type == DpWireType.SET: prot.read_set_end()
            else: prot.read_list_end()
            return set(res) if wire_type == DpWireType.SET else res
        if wire_type == DpWireType.MAP:
            kwt, vwt, count = prot.read_map_begin()
            ktref, vtref = tref[1], tref[2]
            kwt_r, vwt_r = DpProtocol._get_wire_type(ktref), DpProtocol._get_wire_type(vtref)
            res_dict = {DpProtocol._read_val(prot, kwt_r, ktref, depth + 1): DpProtocol._read_val(prot, vwt_r, vtref, depth + 1) for _ in range(count)}
            prot.read_map_end()
            return res_dict
        return None

    @staticmethod
    def _get_wire_type(tref: Any) -> int:
        if isinstance(tref, str):
            t = tref.lower()
            if t == "bool": return DpWireType.BOOL
            if t in ("byte", "int8"): return DpWireType.BYTE
            if t == "int16": return DpWireType.INT16
            if t == "int32": return DpWireType.INT32
            if t == "int64": return DpWireType.INT64
            if t in ("float", "double"): return DpWireType.DOUBLE
            if t == "string": return DpWireType.STRING
            if t == "binary": return DpWireType.BINARY
            return DpWireType.STRUCT
        if isinstance(tref, list) or isinstance(tref, tuple):
            if tref[0] in ("list", "set"): return DpWireType.LIST
            if tref[0] == "map": return DpWireType.MAP
        return DpWireType.STRUCT

# Convenience aliases
TBinaryProtocol  = DpTBinaryProtocol
TCompactProtocol = DpTCompactProtocol
PackProtocol     = DpPackProtocol
ProtobufProtocol = DpProtobufProtocol
JsonProtocol     = DpJsonProtocol
