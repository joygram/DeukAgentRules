#pragma once
#include <cstdint>
#include <string>
#include <vector>
#include <cstring>
#include "DpProtocol.h" // For DpWireType

// V2.0 Zero-Copy Array Writer (No Virtual, No Stream)
class ZeroCopyWriter {
    uint8_t* cursor_;
public:
    ZeroCopyWriter(uint8_t* buffer) : cursor_(buffer) {}

    // Inline exact writers
    inline void WriteByte(uint8_t value) {
        *cursor_++ = value;
    }

    inline void WriteInt16(int16_t value) {
        *cursor_++ = static_cast<uint8_t>((value >> 8) & 0xFF);
        *cursor_++ = static_cast<uint8_t>(value & 0xFF);
    }

    inline void WriteInt32(int32_t value) {
        *cursor_++ = static_cast<uint8_t>((value >> 24) & 0xFF);
        *cursor_++ = static_cast<uint8_t>((value >> 16) & 0xFF);
        *cursor_++ = static_cast<uint8_t>((value >> 8) & 0xFF);
        *cursor_++ = static_cast<uint8_t>(value & 0xFF);
    }

    inline void WriteInt64(int64_t value) {
        for (int i = 7; i >= 0; --i) {
            *cursor_++ = static_cast<uint8_t>((value >> (i * 8)) & 0xFF);
        }
    }

    inline void WriteDouble(double value) {
        union { double d; int64_t i; } u;
        u.d = value;
        WriteInt64(u.i);
    }

    inline void WriteFloat(float value) {
        union { float f; int32_t i; } u;
        u.f = value;
        WriteInt32(u.i);
    }

    inline void WriteInt8(int8_t value) { WriteByte(static_cast<uint8_t>(value)); }
    inline void WriteUInt16(uint16_t value) { WriteInt16(static_cast<int16_t>(value)); }
    inline void WriteUInt32(uint32_t value) { WriteInt32(static_cast<int32_t>(value)); }
    inline void WriteUInt64(uint64_t value) { WriteInt64(static_cast<int64_t>(value)); }

    inline void WriteString(const std::string& value) {
        WriteInt32Var(IntToZigZag(static_cast<int32_t>(value.length())));
        if (!value.empty()) {
            std::memcpy(cursor_, value.data(), value.length());
            cursor_ += value.length();
        }
    }

    inline void WriteInt32Var(int32_t n) {
        uint32_t v = static_cast<uint32_t>(n);
        while (v > 0x7F) {
            *cursor_++ = static_cast<uint8_t>((v & 0x7F) | 0x80);
            v >>= 7;
        }
        *cursor_++ = static_cast<uint8_t>(v);
    }

    inline int32_t IntToZigZag(int32_t n) { return (n << 1) ^ (n >> 31); }

    // DeukPack Format Helpers
    inline void WriteFieldHeader(int32_t id, uint8_t wireType) {
        WriteInt32Var((id << 3) | (wireType & 0x07));
    }

    inline void WriteFieldBegin(uint8_t type, int32_t id) {
        WriteByte(type);
        WriteInt16(static_cast<int16_t>(id));
    }

    inline void WriteFieldStop() {
        WriteByte(static_cast<uint8_t>(deuk::DpWireType::Stop));
    }

    inline void WriteListBegin(uint8_t elem_type, int32_t count) {
        WriteByte(elem_type);
        WriteInt32(count);
    }

    inline void WriteSetBegin(uint8_t elem_type, int32_t count) {
        WriteListBegin(elem_type, count);
    }

    inline void WriteMapBegin(uint8_t key_type, uint8_t val_type, int32_t count) {
        WriteByte(key_type);
        WriteByte(val_type);
        WriteInt32(count);
    }

    uint8_t* GetCursor() const { return cursor_; }
};

// V2.0 Zero-Copy Array Reader (No Virtual, No Stream, Only Pointer Ops)
class ZeroCopyReader {
    const uint8_t* cursor_;
    const uint8_t* end_;
public:
    ZeroCopyReader(const uint8_t* buffer, size_t size) : cursor_(buffer), end_(buffer + size) {}

    inline uint8_t ReadByte() {
        return (cursor_ < end_) ? *cursor_++ : 0;
    }

    inline int16_t ReadInt16() {
        if (cursor_ + 2 > end_) return 0;
        int16_t res = (static_cast<int16_t>(cursor_[0]) << 8) | static_cast<int16_t>(cursor_[1]);
        cursor_ += 2;
        return res;
    }

    inline int32_t ReadInt32() {
        if (cursor_ + 4 > end_) return 0;
        int32_t res = (static_cast<int32_t>(cursor_[0]) << 24) |
                      (static_cast<int32_t>(cursor_[1]) << 16) |
                      (static_cast<int32_t>(cursor_[2]) << 8) |
                      static_cast<int32_t>(cursor_[3]);
        cursor_ += 4;
        return res;
    }

    inline int32_t ReadInt32Var() {
        int32_t res = 0, shift = 0;
        while (true) {
            uint8_t b = ReadByte();
            res |= static_cast<int32_t>(b & 0x7F) << shift;
            if ((b & 0x80) == 0) break;
            shift += 7;
        }
        return res;
    }

    inline int32_t ZigZagToInt(int32_t n) { return static_cast<int32_t>((static_cast<uint32_t>(n) >> 1) ^ -(n & 1)); }

    inline bool ReadFieldHeader(int32_t& id, uint8_t& wireType) {
        if (cursor_ >= end_) return false;
        int32_t val = ReadInt32Var();
        if (val == 0) return false; // FieldStop is 0
        id = val >> 3;
        wireType = val & 0x07;
        return true;
    }

    inline int64_t ReadInt64() {
        if (cursor_ + 8 > end_) return 0;
        int64_t res = 0;
        for (int i = 7; i >= 0; --i) {
            res |= (static_cast<int64_t>(*cursor_++) << (i * 8));
        }
        return res;
    }

    inline double ReadDouble() {
        union { int64_t i; double d; } u;
        u.i = ReadInt64();
        return u.d;
    }

    inline float ReadFloat() {
        union { int32_t i; float f; } u;
        u.i = ReadInt32();
        return u.f;
    }

    inline int8_t ReadInt8() { return static_cast<int8_t>(ReadByte()); }
    inline uint16_t ReadUInt16() { return static_cast<uint16_t>(ReadInt16()); }
    inline uint32_t ReadUInt32() { return static_cast<uint32_t>(ReadInt32()); }
    inline uint64_t ReadUInt64() { return static_cast<uint64_t>(ReadInt64()); }

    inline std::string ReadString() {
        int32_t len = ZigZagToInt(ReadInt32Var());
        if (len <= 0) return "";
        std::string res(reinterpret_cast<const char*>(cursor_), len);
        cursor_ += len;
        return res;
    }

    inline bool ReadFieldBegin(uint8_t& type, int16_t& id) {
        if (cursor_ >= end_) return false;
        type = ReadByte();
        if (type == static_cast<uint8_t>(deuk::DpWireType::Stop)) return false;
        id = ReadInt16();
        return true;
    }

    inline void ReadListBegin(uint8_t& elem_type, int32_t& count) {
        elem_type = ReadByte();
        count = ReadInt32();
    }

    inline void ReadSetBegin(uint8_t& elem_type, int32_t& count) {
        ReadListBegin(elem_type, count);
    }

    inline void ReadMapBegin(uint8_t& key_type, uint8_t& val_type, int32_t& count) {
        key_type = ReadByte();
        val_type = ReadByte();
        count = ReadInt32();
    }

    inline void Skip(uint8_t wire_type) {
        switch (wire_type) {
            case 0: ReadByte(); break;    // 1-byte
            case 1: cursor_ += 2; break;  // 2-byte
            case 2: cursor_ += 4; break;  // 4-byte
            case 3: cursor_ += 8; break;  // 8-byte
            case 4: {                     // Length-delimited (String/Binary/etc)
                int32_t len = ZigZagToInt(ReadInt32Var());
                if (len > 0) cursor_ += len;
                break;
            }
            default: break;
        }
        if (cursor_ > end_) cursor_ = end_;
    }
};
