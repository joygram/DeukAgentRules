package <%- locals.JAVA_PACKAGE %>;

public class DpColumn {
    public String Name = "";
    public DpWireType Type = DpWireType.Stop;
    public int ID = 0;
    public int WireType = 0;
    public DpColumn() {}
    public DpColumn(String name, DpWireType type, int id) {
        this.Name = name;
        this.Type = type;
        this.ID = id;
    }
    public DpColumn(String name, DpWireType type, int id, int wireType) {
        this.Name = name;
        this.Type = type;
        this.ID = id;
        this.WireType = wireType;
    }
}
