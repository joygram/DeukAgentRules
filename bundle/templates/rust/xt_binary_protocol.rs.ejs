    }
    #[inline(always)] fn read_int16(&mut self) -> Result<i16, Error> {
        if self.offset + 2 > self.buffer.len() { return Ok(0); }
        let bytes = [self.buffer[self.offset], self.buffer[self.offset + 1]];
        self.offset += 2;
        Ok(i16::from_le_bytes(bytes))
    }
    #[inline(always)] fn read_int32(&mut self) -> Result<i32, Error> {
        if self.offset + 4 > self.buffer.len() { return Ok(0); }
        let bytes = [self.buffer[self.offset], self.buffer[self.offset+1], self.buffer[self.offset+2], self.buffer[self.offset+3]];
        self.offset += 4;
        Ok(i32::from_le_bytes(bytes))
    }
    #[inline(always)] fn read_int64(&mut self) -> Result<i64, Error> {
        if self.offset + 8 > self.buffer.len() { return Ok(0); }
        let bytes: [u8; 8] = self.buffer[self.offset..self.offset + 8].try_into().unwrap_or_default();
        self.offset += 8;
        Ok(i64::from_le_bytes(bytes))
    }
    #[inline(always)] fn read_f64(&mut self) -> Result<f64, Error> {
        let val = self.read_int64()?;
        Ok(f64::from_bits(val as u64))
    }
    #[inline(always)] fn read_f32(&mut self) -> Result<f32, Error> {
        if self.offset + 4 > self.buffer.len() { return Ok(0.0); }
        let bytes: [u8; 4] = self.buffer[self.offset..self.offset + 4].try_into().unwrap_or_default();
        self.offset += 4;
        Ok(f32::from_le_bytes(bytes))
    }
    #[inline(always)] fn read_bool(&mut self) -> Result<bool, Error> { Ok(self.read_byte()? != 0) }
    #[inline(always)] fn read_int8(&mut self) -> Result<i8, Error> { Ok(self.read_byte()? as i8) }
    #[inline(always)] fn read_string(&mut self) -> Result<String, Error> {
        let raw = self.read_varint();
        let len = Self::zigzag_decode(raw);
        if len < 0 { return Ok(String::new()); }
        let len = len as usize;
        if len == 0 || self.offset + len > self.buffer.len() { return Ok(String::new()); }
        let s = String::from_utf8_lossy(&self.buffer[self.offset..self.offset + len]).into_owned();
        self.offset += len;
        Ok(s)
    }
    #[inline(always)] fn read_binary(&mut self) -> Result<Vec<u8>, Error> {
        let raw = self.read_varint();
        let len = Self::zigzag_decode(raw);
        if len <= 0 { return Ok(Vec::new()); }
        let len = len as usize;
        if self.offset + len > self.buffer.len() { return Ok(Vec::new()); }
        let b = self.buffer[self.offset..self.offset + len].to_vec();
        self.offset += len;
        Ok(b)
    }
    #[inline(always)] fn read_field_begin(&mut self) -> Result<(WireType, i32), Error> {
        self.ensure_magic();
        let id = self.read_varint() as i32;
        if id == 0 { return Ok((WireType::Stop, 0)); }
        Ok((WireType::Void, id))
    }
    #[inline(always)] fn read_list_begin(&mut self) -> Result<(WireType, i32), Error> {
        let count = self.read_varint() as i32;
        Ok((WireType::Stop, count))
    }
    #[inline(always)] fn read_set_begin(&mut self) -> Result<(WireType, i32), Error> { self.read_list_begin() }
    #[inline(always)] fn read_map_begin(&mut self) -> Result<(WireType, WireType, i32), Error> {
        let count = self.read_varint() as i32;
        Ok((WireType::Stop, WireType::Stop, count))
    }
}

// Legacy aliases for backwards compatibility
pub type PackProtocolWriter = PackV2ProtocolWriter;
pub type PackProtocolReader<'a> = PackV2ProtocolReader<'a>;

